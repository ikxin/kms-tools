    "@nuxtjs/tailwindcss": "^6.14.0",
    "@vueuse/nuxt": "14.2.1",
    "arco-design-nuxt-module": "^0.2.1",
    "echarts": "^6.0.0",
    "node-vlmcs": "workspace:*",
    "nuxt": "^4.4.2",
    "nuxt-echarts": "^1.0.1",
    "oxfmt": "^0.43.0",
    "vue": "3.5.31"
  }
